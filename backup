name: ProdBackup

on:
workflow_dispatch:

jobs:
backup:
runs-on: ubuntu-latest
steps:
- uses: actions/checkout@v3
- run: npm install -g @salesforce/cli
- run: echo "${{ secrets.SFDX_AUTH_URL_PROD }}" > auth.txt
- run: sf org login sfdx-url --sfdx-url-file auth.txt --alias prod
- run: sf project retrieve start --target-org prod --metadata ApexClass
- run: |
git config user.name "github-actions"
git config user.email "[github-actions@github.com](mailto:github-actions@github.com)"
git add .
git commit -m "Backup" || echo "No changes"
git push
